# Copy this file to `.env` and fill in real values for your local environment.
# `.env` is git-ignored. Never commit secrets.

# Application environment: "development" | "production"
APP_ENV=development

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/brand_decision_dev

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
